# Server
PORT=3001
NODE_ENV=development

# MongoDB
DATABASE_URI=mongodb://localhost:27017/iceCreamWorkshop

# Authentication
# IMPORTANT: In production, set a strong random value for JWT_SECRET
JWT_SECRET=gelatari-dev-secret-change-in-production
# Optional: customize salt rounds (default: 12)
SALT_ROUNDS=12
# Optional: customize token expiry duration (default: 7d)
TOKEN_EXPIRY=7d

# Default user seeding (only used when no users exist in the database)
# IMPORTANT: In production, set strong unique values here
DEFAULT_USERNAME=tresxalats
DEFAULT_PASSWORD=placeholder

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
